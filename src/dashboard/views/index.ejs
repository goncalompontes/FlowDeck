<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= project %> — Dashboard</title>
  <style>
    /* === Design Tokens === */
    :root {
      --color-bg: #111827;
      --color-surface: #1F2937;
      --color-border: #374151;
      --color-accent: #3B82F6;
      --color-accent-hover: #2563eb;
      --color-text-primary: #f9fafb;
      --color-text-secondary: #d1d5db;
      --color-text-muted: #9ca3af;
      --color-success: #10b981;
      --color-danger: #ef4444;
      --color-pending: #6b7280;

      --space-xs: 4px;
      --space-sm: 8px;
      --space-md: 16px;
      --space-lg: 24px;
      --space-xl: 32px;
      --space-2xl: 48px;
      --space-3xl: 64px;

      --font-display: 28px;
      --font-heading: 20px;
      --font-body: 14px;
      --font-label: 12px;

      --radius-sm: 4px;
      --radius-md: 8px;
      --radius-lg: 12px;
    }

    /* === Reset & Base === */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background: var(--color-bg);
      color: var(--color-text-primary);
      font-family: system-ui, -apple-system, sans-serif;
      font-size: var(--font-body);
      line-height: 1.5;
      min-height: 100vh;
    }

    /* === Typography === */
    .display {
      font-size: var(--font-display);
      font-weight: 700;
      line-height: 1.1;
      color: var(--color-text-primary);
    }
    .heading {
      font-size: var(--font-heading);
      font-weight: 600;
      line-height: 1.2;
      color: var(--color-text-primary);
    }
    .label {
      font-size: var(--font-label);
      font-weight: 500;
      color: var(--color-text-muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .body {
      font-size: var(--font-body);
      font-weight: 400;
      color: var(--color-text-secondary);
    }

    /* === Layout === */
    .page {
      max-width: 800px;
      margin: 0 auto;
      padding: var(--space-xl) var(--space-md);
    }

    /* === Header === */
    .header {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      padding: var(--space-lg);
      margin-bottom: var(--space-lg);
    }
    .header-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: var(--space-md);
    }
    .header-milestone {
      display: flex;
      align-items: center;
      gap: var(--space-sm);
      margin-top: var(--space-xs);
    }
    .refresh-link {
      display: inline-flex;
      align-items: center;
      gap: var(--space-xs);
      background: var(--color-accent);
      color: white;
      padding: var(--space-sm) var(--space-md);
      border-radius: var(--radius-md);
      font-size: var(--font-body);
      font-weight: 500;
      text-decoration: none;
      white-space: nowrap;
      flex-shrink: 0;
      transition: background 150ms;
    }
    .refresh-link:hover { background: var(--color-accent-hover); }

    /* === Section Card === */
    .section-card {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      padding: var(--space-lg);
      margin-bottom: var(--space-lg);
    }

    /* === Phase Timeline === */
    .phase-list { display: flex; flex-direction: column; gap: var(--space-xs); margin-top: var(--space-md); }
    .phase-item {
      display: flex;
      align-items: center;
      gap: var(--space-md);
      padding: var(--space-sm) var(--space-md);
      border-radius: var(--radius-md);
      transition: background 150ms;
    }
    .phase-item:last-child { border-bottom: none; }
    .phase-item.phase-complete { background: rgba(16, 185, 129, 0.05); }
    .phase-item.phase-in_progress { background: rgba(59, 130, 246, 0.1); border: 1px solid rgba(59, 130, 246, 0.3); }
    .phase-item.phase-pending { opacity: 0.6; }

    .phase-indicator {
      width: 24px;
      height: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .icon-check { color: var(--color-success); }
    .phase-pulse {
      width: 10px;
      height: 10px;
      background: var(--color-accent);
      border-radius: 50%;
      animation: pulse 2s ease-in-out infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.6; transform: scale(0.85); }
    }
    .phase-dot {
      width: 8px;
      height: 8px;
      background: var(--color-pending);
      border-radius: 50%;
    }

    .phase-content { flex: 1; min-width: 0; }
    .phase-number { font-size: var(--font-label); color: var(--color-text-muted); font-weight: 500; }
    .phase-name { font-size: var(--font-body); color: var(--color-text-primary); font-weight: 400; }

    .phase-status { flex-shrink: 0; }
    .status-complete { font-size: var(--font-label); color: var(--color-success); font-weight: 500; }
    .status-in-progress { font-size: var(--font-label); color: var(--color-accent); font-weight: 600; }
    .status-pending { font-size: var(--font-label); color: var(--color-pending); font-weight: 500; }

    /* === Blockers === */
    .blockers-list { list-style: none; padding: 0; margin-top: var(--space-sm); display: flex; flex-direction: column; gap: var(--space-xs); }
    .blocker-item {
      font-size: var(--font-body);
      color: var(--color-danger);
      padding: var(--space-sm) var(--space-md);
      background: rgba(239, 68, 68, 0.08);
      border-radius: var(--radius-sm);
      border-left: 3px solid var(--color-danger);
    }

    /* === Progress === */
    .progress-section { }
    .progress-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: var(--space-sm);
    }
    .progress-percent {
      font-size: var(--font-heading);
      font-weight: 700;
      color: var(--color-accent);
    }
    .progress-bar-track {
      height: 8px;
      background: var(--color-border);
      border-radius: 4px;
      overflow: hidden;
    }
    .progress-bar-fill {
      height: 100%;
      background: var(--color-accent);
      border-radius: 4px;
      transition: width 300ms ease-out;
    }
    .progress-detail { margin-top: var(--space-sm); }

    /* === Empty State === */
    .empty-state { text-align: center; padding: var(--space-xl) var(--space-md); }
    .empty-state-heading { font-size: var(--font-heading); font-weight: 600; color: var(--color-text-muted); margin-bottom: var(--space-xs); }
    .empty-state-body { font-size: var(--font-body); color: var(--color-pending); }

    /* === Spacing Utilities === */
    .space-sm { height: var(--space-sm); }
    .space-md { height: var(--space-md); }
    .space-lg { height: var(--space-lg); }

    /* === Responsive === */
    @media (max-width: 640px) {
      .header-top { flex-direction: column; }
      .refresh-link { align-self: flex-start; }
      .phase-item { gap: var(--space-sm); }
      .phase-status { display: none; }
    }
  </style>
</head>
<body>
  <main class="page">
    <%- include('partials/header.ejs') %>

    <div class="space-lg"></div>

    <%- include('partials/progress.ejs') %>

    <div class="space-lg"></div>

    <div class="section-card">
      <%- include('partials/phase-timeline.ejs') %>
    </div>

    <%- include('partials/blockers.ejs') %>
  </main>
</body>
</html>
