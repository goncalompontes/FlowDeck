<section class="phase-timeline">
  <div class="heading">Phase Timeline</div>
  <div class="phase-list">
    <% if (phases.length === 0) { %>
      <div class="empty-state">
        <p class="empty-state-heading">No phases yet</p>
        <p class="empty-state-body">Phases will appear here once they are defined in the roadmap.</p>
      </div>
    <% } else { %>
      <% phases.forEach(function(phase) { %>
        <div class="phase-item phase-<%= phase.status %>">
          <div class="phase-indicator">
            <% if (phase.status === 'complete') { %>
              <svg class="icon-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            <% } else if (phase.status === 'in_progress') { %>
              <span class="phase-pulse"></span>
            <% } else { %>
              <span class="phase-dot"></span>
            <% } %>
          </div>
          <div class="phase-content">
            <div class="phase-number">Phase <%= phase.number %></div>
            <div class="phase-name"><%= phase.name %></div>
          </div>
          <div class="phase-status">
            <% if (phase.status === 'complete') { %>
              <span class="status-complete">Complete</span>
            <% } else if (phase.status === 'in_progress') { %>
              <span class="status-in-progress">In Progress</span>
            <% } else { %>
              <span class="status-pending">Pending</span>
            <% } %>
          </div>
        </div>
      <% }); %>
    <% } %>
  </div>
</section>
